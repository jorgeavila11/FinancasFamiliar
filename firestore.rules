rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Helper to check if user is a member of the household
    function isMemberOf(householdId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/households/$(householdId)) &&
             request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == userId && 
               (data.email is string || data.email == null);
      }
      
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'householdId', 'email', 'updatedAt', 'geminiApiKey']);
    }

    // 2. Households Collection
    match /households/{householdId} {
      function isValidHousehold(data) {
        return data.keys().hasAll(['name', 'ownerId', 'members', 'budget']) &&
               data.name is string && data.name.size() <= 100 &&
               data.ownerId is string && 
               data.members is list && data.members.size() >= 1 && 
               data.budget is map &&
               (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt == null);
      }

      allow get: if isSignedIn() && request.auth.uid in existing().members;
      allow list: if isSignedIn() && request.auth.uid in resource.data.members;
      
      allow create: if isSignedIn() && 
                       isValidHousehold(incoming()) && 
                       incoming().ownerId == request.auth.uid &&
                       (!('createdAt' in incoming()) || incoming().createdAt == request.time);
      allow update: if isSignedIn() && 
                       (existing().ownerId == request.auth.uid || request.auth.uid in existing().members) &&
                       isValidHousehold(incoming()) &&
                       incoming().ownerId == existing().ownerId;
    }

    // 3. Expenses Collection
    match /expenses/{expenseId} {
      function isValidExpense(data) {
        return data.keys().hasAll(['amount', 'category', 'merchant', 'date', 'userId', 'householdId', 'createdAt']) &&
               data.amount is number &&
               data.category is string &&
               data.merchant is string &&
               data.date is string &&
               data.userId == request.auth.uid &&
               isValidId(data.householdId) &&
               (data.createdAt is timestamp || data.createdAt == null) &&
               (!('installments' in data) || data.installments is number) &&
               (!('installmentIndex' in data) || data.installmentIndex is number);
      }

      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isMemberOf(resource.data.householdId));
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isMemberOf(existing().householdId));
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isMemberOf(existing().householdId));
      
      allow create: if isSignedIn() && isValidExpense(incoming()) && (incoming().createdAt == request.time || incoming().createdAt == null);
      allow update: if isSignedIn() && 
                       isValidExpense(incoming()) &&
                       incoming().householdId == existing().householdId &&
                       incoming().userId == existing().userId &&
                       (existing().userId == request.auth.uid || isMemberOf(existing().householdId));
    }

    // 4. Goals Collection
    match /goals/{goalId} {
      function isValidGoal(data) {
        return data.keys().hasAll(['title', 'targetAmount', 'savedAmount', 'householdId']) &&
               data.title is string &&
               data.targetAmount is number &&
               data.savedAmount is number &&
               isValidId(data.householdId);
      }

      allow get, delete: if isMemberOf(existing().householdId);
      allow list: if isMemberOf(resource.data.householdId);
      
      allow create: if isMemberOf(incoming().householdId) && isValidGoal(incoming());
      allow update: if isMemberOf(existing().householdId) && 
                       isValidGoal(incoming()) &&
                       incoming().householdId == existing().householdId;
    }

    // 5. Subscriptions Collection
    match /subscriptions/{subscriptionId} {
      function isValidSubscription(data) {
        return data.keys().hasAll(['name', 'amount', 'frequency', 'nextDueDate', 'householdId', 'status']) &&
               data.name is string &&
               data.amount is number &&
               data.frequency is string &&
               data.nextDueDate is string &&
               isValidId(data.householdId);
      }

      allow get, delete: if isMemberOf(existing().householdId);
      allow list: if isMemberOf(resource.data.householdId);
      
      allow create: if isMemberOf(incoming().householdId) && isValidSubscription(incoming());
      allow update: if isMemberOf(existing().householdId) && 
                       isValidSubscription(incoming()) &&
                       incoming().householdId == existing().householdId;
    }

    // 6. Fixed Expenses Collection
    match /fixedExpenses/{fixedExpenseId} {
      function isValidFixedExpense(data) {
        return data.keys().hasAll(['name', 'amount', 'category', 'dueDate', 'householdId']) &&
               data.name is string &&
               data.amount is number &&
               data.category is string &&
               data.dueDate is number &&
               isValidId(data.householdId);
      }

      allow get, delete: if isMemberOf(existing().householdId);
      allow list: if isMemberOf(resource.data.householdId);
      
      allow create: if isMemberOf(incoming().householdId) && isValidFixedExpense(incoming());
      allow update: if isMemberOf(existing().householdId) && 
                       isValidFixedExpense(incoming()) &&
                       incoming().householdId == existing().householdId;
    }
  }
}
