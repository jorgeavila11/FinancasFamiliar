rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Relational Helpers
    function getHousehold(householdId) {
      return get(/databases/$(database)/documents/households/$(householdId)).data;
    }
    
    function isHouseholdMember(householdId) {
      return isSignedIn() && request.auth.uid in getHousehold(householdId).members;
    }

    function isHouseholdOwner(householdId) {
      return isSignedIn() && getHousehold(householdId).ownerId == request.auth.uid;
    }

    // Test connection collection
    match /test/connection {
      allow read: if true;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256;
      }
      
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId && 
                       isValidUser(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'householdId']);
    }

    // 2. Households Collection
    match /households/{householdId} {
      function isValidHousehold(data) {
        return data.keys().hasAll(['name', 'ownerId', 'members', 'budget']) &&
               data.name is string && data.name.size() <= 100 &&
               data.ownerId == request.auth.uid && 
               data.members is list && data.members.size() <= 20 &&
               data.members[0] is string &&
               (!data.keys().contains('monthlyIncome') || data.monthlyIncome is number);
      }

      allow get: if isSignedIn() && request.auth.uid in existing().members;
      allow list: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isVerified() && isValidHousehold(incoming());
      allow update: if isVerified() && 
                       (isHouseholdOwner(householdId) || (isHouseholdMember(householdId) && incoming().diff(existing()).affectedKeys().hasOnly(['members', 'budget', 'monthlyIncome']))) &&
                       isValidHousehold(incoming());
    }

    // 3. Expenses Collection
    match /expenses/{expenseId} {
      function isValidExpense(data) {
        return data.keys().hasAll(['amount', 'category', 'merchant', 'date', 'userId', 'householdId']) &&
               data.amount is number && data.amount > 0 &&
               data.category is string &&
               data.merchant is string &&
               data.date is string &&
               data.userId == request.auth.uid &&
               isValidId(data.householdId);
      }

      allow get: if isSignedIn() && isHouseholdMember(existing().householdId);
      allow list: if isSignedIn() && isHouseholdMember(resource.data.householdId);
      allow delete: if isVerified() && isHouseholdMember(existing().householdId);
      allow create: if isVerified() && isHouseholdMember(incoming().householdId) && isValidExpense(incoming());
      allow update: if isVerified() && isHouseholdMember(existing().householdId) && 
                       isValidExpense(incoming()) &&
                       incoming().householdId == existing().householdId &&
                       incoming().userId == existing().userId;
    }

    // 4. Goals Collection
    match /goals/{goalId} {
      function isValidGoal(data) {
        return data.keys().hasAll(['title', 'targetAmount', 'savedAmount', 'householdId']) &&
               data.title is string && data.title.size() <= 100 &&
               data.targetAmount is number &&
               data.savedAmount is number &&
               isValidId(data.householdId);
      }

      allow get, delete: if isVerified() && isHouseholdMember(existing().householdId);
      allow list: if isVerified() && isHouseholdMember(resource.data.householdId);
      allow create: if isVerified() && isHouseholdMember(incoming().householdId) && isValidGoal(incoming());
      allow update: if isVerified() && isHouseholdMember(existing().householdId) && 
                       isValidGoal(incoming()) &&
                       incoming().householdId == existing().householdId;
    }

    // 5. Subscriptions Collection
    match /subscriptions/{subscriptionId} {
      function isValidSubscription(data) {
        return data.keys().hasAll(['name', 'amount', 'frequency', 'nextDueDate', 'householdId', 'status']) &&
               data.name is string &&
               data.amount is number &&
               data.frequency is string &&
               data.nextDueDate is string &&
               data.status in ['active', 'pending', 'action_needed'] &&
               isValidId(data.householdId);
      }

      allow get, delete: if isVerified() && isHouseholdMember(existing().householdId);
      allow list: if isVerified() && isHouseholdMember(resource.data.householdId);
      allow create: if isVerified() && isHouseholdMember(incoming().householdId) && isValidSubscription(incoming());
      allow update: if isVerified() && isHouseholdMember(existing().householdId) && 
                       isValidSubscription(incoming()) &&
                       incoming().householdId == existing().householdId;
    }

    // 6. Fixed Expenses Collection
    match /fixedExpenses/{fixedExpenseId} {
      function isValidFixedExpense(data) {
        return data.keys().hasAll(['name', 'amount', 'category', 'dueDate', 'householdId']) &&
               data.name is string && data.name.size() <= 100 &&
               data.amount is number && data.amount > 0 &&
               data.category is string &&
               data.dueDate is number && data.dueDate >= 1 && data.dueDate <= 31 &&
               isValidId(data.householdId);
      }

      allow get, delete: if isVerified() && isHouseholdMember(existing().householdId);
      allow list: if isVerified() && isHouseholdMember(resource.data.householdId);
      allow create: if isVerified() && isHouseholdMember(incoming().householdId) && isValidFixedExpense(incoming());
      allow update: if isVerified() && isHouseholdMember(existing().householdId) && 
                       isValidFixedExpense(incoming()) &&
                       incoming().householdId == existing().householdId;
    }
  }
}
